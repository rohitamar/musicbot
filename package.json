  "license": "ISC",
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@noble/ciphers": "^2.2.0",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "ffmpeg-static": "^5.3.0",
    "opusscript": "^0.0.8",
    "pino": "^9.9.4"
  },
  "devDependencies": {
    "@types/node": "^24.9.0",
    "axios": "^1.15.2",
    "pino-pretty": "^13.1.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
