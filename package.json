{
  "name": "musicbot",
  "version": "1.0.0",
  "description": "When a person joins the VC, a custom song is played.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file=.env index.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "npm run build && node -e \"process.env.NODE_ENV='production'; require('./dist/index.js')\"",
    "typecheck": "tsc --noEmit"
  },
